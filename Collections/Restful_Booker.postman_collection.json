    {
      "name": "CreateBooking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Genarate first Name \r",
              "var firstname = pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "pm.environment.set(\"fname\", firstname);\r",
              "\r",
              "//Genarte last name \r",
              "var lastName = pm.variables.replaceIn('{{$randomLastName}}');\r",
              "pm.environment.set(\"lname\", lastName);\r",
              "\r",
              "//Genarte total proce \r",
              "var totalPrice = pm.variables.replaceIn('{{$randomInt}}');\r",
              "pm.environment.set(\"totalprice\", totalPrice);\r",
              "\r",
              "//Genarte depositpaid \r",
              "var depositpaid = pm.variables.replaceIn('{{$randomBoolean}}');\r",
              "pm.environment.set(\"depositpaid\", depositpaid);\r",
              "\r",
              "// Genarte checkIn\r",
              "var checkIn = require('moment')().format('YYYY-MM-DD');\r",
              "pm.environment.set(\"checkIn\", checkIn);\r",
              "\r",
              "//Genarte checkOut\r",
              "var checkOut = require('moment')().add(Math.floor(Math.random() * 10 )+ 1 , 'd').format('YYYY-MM-DD');\r",
              "pm.environment.set(\"checkOut\", checkOut);\r",
              "\r",
              "//Generate additional needs \r",
              "var additionalneeds = pm.variables.replaceIn('{{$randomBsNoun}}');\r",
              "pm.environment.set(\"additionalneeds\",additionalneeds);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json();\r",
              "pm.environment.set(\"Id\", responseBody.bookingid);\r",
              "\r",
              "// assertion for status code \r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(201);\r",
              "});\r",
              "\r",
              "// assertion for response time \r",
              "pm.test(\"Response time is less than expectation\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});\r",
              "\r",
              "// assertion for response file size\r",
              "pm.test(\"Response size is less than expectation\", function () {\r",
              "    pm.expect(pm.response.responseSize).to.be.below(50000);\r",
              "    });\r",
              "\r",
              "//assertion for first Name \r",
              "pm.test(\"Verify First Name\",function(){\r",
              "    pm.expect(pm.environment.get(\"fname\")).to.eql(pm.response.json().booking.firstname);\r",
              "});\r",
              "\r",
              "//assertion for last Name \r",
              "pm.test(\"Verify Last Name\",function(){\r",
              "    pm.expect(pm.environment.get(\"lname\")).to.eql(pm.response.json().booking.lastname);\r",
              "    });\r",
              "\r",
              "//assertion for totalPrice \r",
              "pm.test(\"Verify Total Price\",function(){\r",
              "    pm.expect(pm.environment.get(\"totalprice\")).to.eql(pm.response.json().booking.totalprice.toString());\r",
              "    });\r",
              "\r",
              "//assertion for depositpaid\r",
              "pm.test(\"Verify the deposite paid status\",function(){\r",
              "    pm.expect(pm.environment.get(\"depositpaid\")).to.eql(pm.response.json().booking.depositpaid.toString());\r",
              "});\r",
              "\r",
              "//assertion for checkIn\r",
              "pm.test(\"Verify CheckIn date\",function(){\r",
              "    pm.expect(pm.environment.get(\"checkIn\")).to.eql(pm.response.json().booking.bookingdates.checkin);\r",
              "});\r",
              "\r",
              "//assertion for checkOut\r",
              "pm.test(\"Verify CheckOut date\",function(){\r",
              "    pm.expect(pm.environment.get(\"checkOut\")).to.eql(pm.response.json().booking.bookingdates.checkout);\r",
              "    });\r",
              "\r",
              "//assertion for additional needs \r",
              "pm.test(\"Verify Additional Needs\",function(){\r",
              "    pm.expect(pm.environment.get(\"additionalneeds\")).to.eql(pm.response.json().booking.additionalneeds);\r",
              "});\r",
              "\r",
              "//assertion for the json data\r",
              "pm.test(\"Verify the data format\",function(){\r",
              "    pm.response.to.have.jsonBody();\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
